---
import { ExplorerApp } from "@/components/ExplorerApp";
import { FeaturedWorldsCarousel } from "@/components/FeaturedWorldsCarousel";
import MainLayout from "@/layouts/MainLayout.astro";
import summaryData from "@/generated/exoplanets-summary.json";
import { formatCompact, formatNumber } from "@/lib/explorer";
import type { ExplorerDataset } from "@/lib/types";

const dataset = summaryData as Pick<ExplorerDataset, "generatedAt" | "source" | "summary" | "featuredWorlds">;
const repoUrl = "https://github.com/johnnylemonny/ExoVault";
const description = "ExoVault is a premium NASA data archive explorer. Discover, filter, and compare thousands of worlds beyond our star through a fast, atmospheric interface.";
const assetBase = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const stats = [
  { label: "Current planets", value: formatCompact(dataset.summary.planetCount), detail: "Default NASA parameter set" },
  { label: "Host systems", value: formatCompact(dataset.summary.hostCount), detail: "Across confirmed archive entries" },
  { label: "Discovery methods", value: formatNumber(dataset.summary.methodCount), detail: "From radial velocity to direct imaging" },
  { label: "Archive span", value: `${dataset.summary.minDiscoveryYear}-${dataset.summary.maxDiscoveryYear}`, detail: "A rolling timeline of discoveries" }
];
---

<MainLayout title="ExoVault | NASA Exoplanet Archive" description={description}>
  <header class="sticky top-0 z-40 border-b border-white/10 bg-[color:color-mix(in_oklch,var(--surface)_72%,transparent)] backdrop-blur-2xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4 sm:px-6 lg:px-8">
      <a href="#hero" class="flex items-center gap-3 text-[var(--foreground)]">
        <img src={`${assetBase}favicon.svg`} alt="ExoVault logo" class="h-10 w-10" />
        <div>
          <p class="font-display text-xl tracking-tight leading-none">ExoVault</p>
          <p class="mt-1 text-[0.62rem] uppercase tracking-[0.3em] text-[var(--muted)]">Archive explorer</p>
        </div>
      </a>

      <nav class="hidden items-center gap-6 text-sm md:flex">
        <a class="nav-link" href="#featured">Featured</a>
        <a class="nav-link" href="#explorer">Explorer</a>
        <a class="nav-link" href="#guide">Guide</a>
        <a class="nav-link" href="#archive">Archive</a>
      </nav>

      <div class="flex items-center gap-3">
        <a class="action-button-secondary hidden sm:flex" href={repoUrl} target="_blank" rel="noreferrer">GitHub repo</a>
      </div>
    </div>
  </header>

  <main id="content">
    <section id="hero" class="mx-auto grid max-w-7xl gap-10 px-4 pb-14 pt-10 sm:px-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(20rem,0.9fr)] lg:px-8 lg:pb-24 lg:pt-14">
      <div class="space-y-8">
        <div class="space-y-5">
          <span class="eyebrow">A premium archive for the NASA Planetary Systems dataset</span>
          <h1 class="max-w-4xl text-balance font-display text-5xl leading-[0.95] text-[var(--foreground)] sm:text-6xl xl:text-7xl">The most elegant way to explore worlds beyond our own star.</h1>
          <p class="max-w-2xl text-lg leading-8 text-[var(--foreground-soft)]">ExoVault turns raw NASA astronomical snapshots into a professional discovery tool. Designed for curation, side-by-side analysis, and atmospheric exploration.</p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="action-button-primary" href="#explorer">Launch explorer</a>
          <a class="action-button-secondary" href="#featured">View featured worlds</a>
        </div>

        <div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-4">
          {stats.map((stat) => (
            <article class="glass-panel min-h-36 p-5">
              <p class="data-label">{stat.label}</p>
              <p class="mt-4 font-display text-4xl text-[var(--foreground)]">{stat.value}</p>
              <p class="mt-3 max-w-[16rem] text-sm leading-6 text-[var(--foreground-soft)]">{stat.detail}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="relative isolate overflow-hidden rounded-[2rem] border border-white/12 bg-[color:var(--surface-strong)] p-6 shadow-[0_30px_120px_-60px_rgba(7,22,48,0.85)]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_color-mix(in_oklch,var(--accent)_42%,transparent),transparent_38%),radial-gradient(circle_at_bottom_left,_color-mix(in_oklch,var(--accent-2)_35%,transparent),transparent_42%)] opacity-90"></div>
        <div class="relative flex h-full flex-col justify-between gap-10">
          <div>
            <p class="eyebrow">Signal overview</p>
            <h2 class="mt-3 max-w-md font-display text-3xl text-[var(--foreground)]">Editorial shell outside, high-signal explorer inside.</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
            <div class="relative aspect-square max-w-sm overflow-hidden rounded-[1.75rem] border border-white/12 bg-[color:var(--surface)]">
              <div class="orbit orbit-one"></div>
              <div class="orbit orbit-two"></div>
              <div class="orbit orbit-three"></div>
              <div class="orbital-node orbital-node-a"></div>
              <div class="orbital-node orbital-node-b"></div>
              <div class="orbital-node orbital-node-c"></div>
              <div class="absolute inset-0 m-auto h-16 w-16 rounded-full bg-[radial-gradient(circle,_color-mix(in_oklch,var(--accent)_68%,white),transparent_70%)] blur-2xl"></div>
              <div class="absolute inset-0 m-auto h-4 w-4 rounded-full bg-[var(--accent)] shadow-[0_0_24px_color-mix(in_oklch,var(--accent)_70%,transparent)]"></div>
            </div>
            <div class="space-y-3 sm:max-w-[12rem]">
              <article class="rounded-[1.5rem] border border-white/10 bg-white/8 p-4 backdrop-blur-md"><p class="data-label">Featured logic</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">Build-time heuristics surface the nearest, hottest, busiest, and freshest archive entries.</p></article>
              <article class="rounded-[1.5rem] border border-white/10 bg-white/8 p-4 backdrop-blur-md"><p class="data-label">Explorer mode</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">Search only when needed, then sort, inspect, and compare without losing context.</p></article>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="featured" class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="mb-8 max-w-3xl">
        <span class="eyebrow">Featured worlds</span>
        <h2 class="section-title mt-3">Six curated entry points into the archive.</h2>
        <p class="section-copy mt-4">Instead of dropping visitors into a wall of rows, the homepage starts with a guided set of extreme, nearby, and surprisingly balanced worlds. Each card can jump directly into the explorer.</p>
      </div>
      <FeaturedWorldsCarousel client:visible items={dataset.featuredWorlds} />
    </section>

    <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="grid gap-5 xl:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
        <article class="glass-panel p-6 md:p-7">
          <span class="eyebrow">User journey</span>
          <h2 class="section-title mt-3">Start broad, move into a slice, then zoom into a single world.</h2>
          <p class="section-copy mt-4">The interface keeps the first decision lightweight. Visitors can enter through a preset, run a manual query, or open a featured planet directly into the detail panel. Compare mode stays optional until curiosity turns into analysis.</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4 sm:col-span-2">
              <span class="data-label">Step 1</span>
              <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">Preset discovery</h3>
              <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Curated filters narrow the archive instantly without forcing technical knowledge first.</p>
              <div class="mt-4 flex flex-wrap gap-2 text-xs uppercase tracking-[0.2em] text-[var(--muted)]">
                <span class="action-chip">Hot worlds</span>
                <span class="action-chip">Nearby systems</span>
                <span class="action-chip">Fresh finds</span>
              </div>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <span class="data-label">Step 2</span>
              <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">Focused search</h3>
              <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Year, method, facility, host name, distance, and heat can be combined into a clean search state.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <span class="data-label">Step 3</span>
              <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">Fast compare</h3>
              <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Pin up to three planets and keep scale, distance, and heat in view without leaving the archive.</p>
            </div>
          </div>
        </article>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
          <article class="feature-card feature-card-compact sm:col-span-2 xl:col-span-1">
            <span class="eyebrow">Interaction model</span>
            <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">A short, guided path keeps the first pass calm.</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Visitors can stay in overview mode, then progressively reveal detail only when they need it.</p>
          </article>
          <article class="feature-card feature-card-compact">
            <span class="eyebrow">Preset-first</span>
            <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">Curated slices</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Small entry points reduce the intimidation of a large scientific archive.</p>
          </article>
          <article class="feature-card feature-card-compact">
            <span class="eyebrow">Compare second</span>
            <h3 class="mt-3 font-display text-2xl text-[var(--foreground)]">Side-by-side reading</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--foreground-soft)]">Comparison stays optional, helping the interface feel exploratory instead of academic.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="explorer" class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="mb-8 max-w-3xl">
        <span class="eyebrow">Main explorer</span>
        <h2 class="section-title mt-3">A static-site data app that still feels alive.</h2>
        <p class="section-copy mt-4">The dataset is pre-processed at build time, then loaded as a static JSON asset, so the explorer can stay responsive on GitHub Pages without forcing a raw NASA CSV through the browser.</p>
      </div>
      <ExplorerApp client:load dataUrl={`${assetBase}data/exoplanets-data.json`} />
    </section>

    <section id="guide" class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="grid gap-5 xl:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)]">
        <article class="feature-card min-h-72">
          <span class="eyebrow">How to read the data</span>
          <h2 class="section-title mt-3">Three simple cues keep the archive approachable.</h2>
          <ul class="mt-5 grid gap-4 text-sm leading-6 text-[var(--foreground-soft)]">
            <li><strong class="text-[var(--foreground)]">Distance</strong> is shown in light-years for easier intuition than raw parsecs.</li>
            <li><strong class="text-[var(--foreground)]">Heat</strong> uses equilibrium temperature, a useful directional signal even though it is not a full climate model.</li>
            <li><strong class="text-[var(--foreground)]">Size class</strong> translates raw radius estimates into human-readable buckets like terrestrial or gas giant.</li>
          </ul>
        </article>
        <article class="glass-panel p-6 md:p-7">
          <span class="eyebrow">What makes this demo different</span>
          <h2 class="section-title mt-3">Designed for browsing, not just querying.</h2>
          <p class="section-copy mt-4">Many archive demos stop at a form and a table. This one adds a curated front door, cinematic but restrained presentation, a persistent detail context, a real compare mode, and a workflow that keeps the dataset fresh without needing a backend.</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <p class="data-label">Curated entry</p>
              <p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">Featured worlds give visitors a fast, low-friction on-ramp.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <p class="data-label">Detail context</p>
              <p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">The planet detail panel stays pinned alongside the results.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <p class="data-label">Static delivery</p>
              <p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">GitHub Pages keeps the experience fast and easy to host.</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4">
              <p class="data-label">Data refresh</p>
              <p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">A scheduled workflow rebuilds the snapshot when NASA updates it.</p>
            </div>
          </div>
          <a class="action-button-secondary mt-6 w-fit" href={repoUrl} target="_blank" rel="noreferrer">Open the source on GitHub</a>
        </article>
      </div>
    </section>

    <section id="archive" class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="grid gap-5 lg:grid-cols-[minmax(0,1.12fr)_minmax(0,0.88fr)]">
        <article class="glass-panel p-6 md:p-7">
          <span class="eyebrow">Archive provenance</span>
          <h2 class="section-title mt-3">Built from NASA's Planetary Systems table, then reduced to the current default parameter set.</h2>
          <p class="section-copy mt-4">The build pipeline reads the raw CSV snapshot, keeps the archive's default rows for each current planet, and generates a compact JSON payload for this interface. A separate GitHub Actions workflow can refresh the NASA snapshot and trigger a new deployment when the data changes.</p>
          <dl class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="feature-card feature-card-compact"><dt class="data-label">Raw snapshot</dt><dd class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">{dataset.source.csvFile}</dd></div>
            <div class="feature-card feature-card-compact"><dt class="data-label">Rows in archive snapshot</dt><dd class="mt-2 font-display text-3xl text-[var(--foreground)]">{formatCompact(dataset.source.archivedRowCount)}</dd></div>
            <div class="feature-card feature-card-compact"><dt class="data-label">Rows in live app payload</dt><dd class="mt-2 font-display text-3xl text-[var(--foreground)]">{formatCompact(dataset.source.defaultRowCount)}</dd></div>
            <div class="feature-card feature-card-compact"><dt class="data-label">Generated</dt><dd class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">{new Date(dataset.generatedAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</dd></div>
          </dl>
        </article>
        <article class="feature-card min-h-full">
          <span class="eyebrow">Project notes</span>
          <h2 class="section-title mt-3">Static deployment, modern DX, zero backend dependency.</h2>
          <div class="mt-5 grid gap-3">
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4"><p class="data-label">Astro shell</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">Astro powers the shell and route output for GitHub Pages.</p></div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4"><p class="data-label">React islands</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">The explorer, compare mode, theme toggle, and featured carousel stay interactive without bloating the shell.</p></div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4"><p class="data-label">CSS motion</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">Hover states and subtle transitions create atmosphere without Framer Motion.</p></div>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-4"><p class="data-label">GitHub Actions</p><p class="mt-2 text-sm leading-6 text-[var(--foreground-soft)]">CI, Pages deploys, and archive refresh automation run on the current branch.</p></div>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/10 py-8">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 text-sm text-[var(--muted)] sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
      <p>© {new Date().getFullYear()} ExoVault. Independent open-source archive built around publicly accessible NASA data.</p>
      <div class="flex flex-wrap gap-4">
        <a class="nav-link" href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
        <a class="nav-link" href={dataset.source.csvUrl} target="_blank" rel="noreferrer">NASA data source</a>
      </div>
    </div>
  </footer>
</MainLayout>

